#!/bin/sh

if [ -z "$1" ]; then
  echo "Usage: $0 <binary_to_decompile>"
  exit 1
fi

BINARY="$1"
PROJECT_DIR=$(mktemp -d)

ghidra-analyzeHeadless "$PROJECT_DIR" temp_project -import "$BINARY" -postScript MyDecompilator.java

rm -rf "$PROJECT_DIR"


# because ghidra is buggy and doesn't load scripts from custom location
# this java file should be placed somewhere where it will be loaded

