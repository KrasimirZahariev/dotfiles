#!/bin/dash
# vim:filetype=sh

# shellcheck disable=SC1091
. "$SHELL_LIBRARY_HOME/dmenu-prompts.sh"
. "$SHELL_LIBRARY_HOME/messaging.sh"

_VPN_CONFIG_DIR="$XDG_CONFIG_HOME/vpn/"

_vpn_config_file="$(find "$_VPN_CONFIG_DIR" -type f -printf "%f\n" | sort | dmenu_select || err "Invalid config")"
[ -z "$_vpn_config_file" ] && exit

nohup sudo openvpn --config "${_VPN_CONFIG_DIR}${_vpn_config_file}" >/tmp/vpn.log 2>&1 &
